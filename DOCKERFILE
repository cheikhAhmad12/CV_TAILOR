FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y gcc libpq-dev curl ca-certificates libgraphite2-3 fontconfig && \
    TECTONIC_URL="$(curl -fsSL https://api.github.com/repos/tectonic-typesetting/tectonic/releases/latest | grep -Eo 'https://[^"]*tectonic-[0-9.]+-x86_64-unknown-linux-gnu.tar.gz' | head -n1)" && \
    mkdir -p /tmp/tectonic-dist && \
    curl -fsSL "$TECTONIC_URL" -o /tmp/tectonic.tar.gz && \
    tar -xzf /tmp/tectonic.tar.gz -C /tmp/tectonic-dist && \
    install "$(find /tmp/tectonic-dist -type f -name tectonic | head -n1)" /usr/local/bin/tectonic && \
    rm -rf /tmp/tectonic-dist /tmp/tectonic.tar.gz /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app ./app

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
